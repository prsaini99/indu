# ============================================
# Server
# ============================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ============================================
# Database
# ============================================
# Local dev (matches docker-compose.yml: indu:indu123 → indu_dev):
DATABASE_URL=postgresql://indu:indu123@localhost:5432/indu_dev
# Production (AWS RDS — example):
# DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_PASSWORD@your-rds-endpoint.region.rds.amazonaws.com:5432/dbname?schema=public

# ============================================
# JWT — generate strong random secrets in production
# Use: openssl rand -base64 48
# ============================================
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Frontend (used for redirect URLs in emails, Stripe checkout, etc.)
# ============================================
FRONTEND_URL=http://localhost:5173
EMAIL_FROM=noreply@indu.ae

# ============================================
# Stripe (M9 — Payments)
# Test keys: sk_test_..., whsec_...
# Live keys: sk_live_..., whsec_... (production only)
# ============================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ============================================
# Zoom Server-to-Server OAuth (M10 — Video classes)
# Get from: https://marketplace.zoom.us/develop/create
# ============================================
ZOOM_ACCOUNT_ID=xxx
ZOOM_CLIENT_ID=xxx
ZOOM_CLIENT_SECRET=xxx
ZOOM_WEBHOOK_SECRET_TOKEN=xxx

# ============================================
# AWS S3 (Recordings storage)
# Region: me-central-1 (UAE) preferred for UAE-targeted platform
# ============================================
AWS_REGION=me-central-1
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_S3_BUCKET=indu-s3-bucket

# ============================================
# AWS SES (Email notifications)
# If SES is not in me-central-1, use me-south-1 (Bahrain) for SES only.
# Backend code reads these as separate from S3 credentials so you can mix regions.
# ============================================
AWS_SES_ACCESS_KEY_ID=xxx
AWS_SES_SECRET_ACCESS_KEY=xxx
AWS_SES_REGION=me-central-1

# ============================================
# Recording config
# ============================================
RECORDING_MAX_RETRIES=3
